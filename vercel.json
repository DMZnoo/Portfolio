{
  "version": 2,
  "public": false,
  "builds": [
    {"src": "index.js", "use": "@now/node-server"},
    { "src": "package.json", "use": "@now/static-build" }
  ],

  "routes": [
    { "src": "/.*", "dest": "/index.js" },
    { "src": "^/static/(.*)", "dest": "/static/$1" },
    { "src": ".*", "dest": "/index.html" }
  ]
}
